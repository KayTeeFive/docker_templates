HOST_IP=127.0.0.1
HOST_PORT=8080

OLLAMA_DATA=/home/dockeruser/.ollama_data
WEBUI_DATA=/home/dockeruser/.webui_data

# Models: https://ollama.com/models
#OLLAMA_LLM_MODEL=mistral:7b
#OLLAMA_LLM_MODEL=gemma3:4b
#OLLAMA_LLM_MODEL=gemma3:12b
#OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_LLM_MODEL=gpt-oss:20b

OLLAMA_CONTEXT_LENGTH=4096
OLLAMA_KEEP_ALIVE=5m
OLLAMA_GPU_LAYERS=32

# Select AMD GPU by VULKAN
# 0 = AMD Radeon Graphics (RADV GFX1201) (radv) | uma: 0 ...
# 1 = AMD Ryzen 7 9700X 8-Core Processor (RADV RAPHAEL_MENDOCINO) (radv) | uma: 1 ...
# Disable all Vulkan GPUs by setting GGML_VK_VISIBLE_DEVICES=-1
VK_VISIBLE_DEVICES=0

# RAG SETTINGS
QDRANT_DATA=/home/dockeruser/.qdrant_data
ANYLLM_DATA=/home/dockeruser/.anyllm_data
OLLAMA_EMBED_MODEL=nomic-embed-text
