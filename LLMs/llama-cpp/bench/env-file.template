# ══════════════════════════════════════════════════════════════════════════════
#  llama.cpp  —  INFERENCE BENCHMARK  —  env-file.template
#  Copy to .env and edit before running any bench-*.sh script.
# ══════════════════════════════════════════════════════════════════════════════

# ── Model ──────────────────────────────────────────────────────────────────────
# Directory on the HOST that contains your .gguf files.
# The container sees this as /models (read-only).
BENCH_MODELS_DIR=/home/dockeruser/.llama_models

# GGUF model file name (relative to BENCH_MODELS_DIR).
# Examples:
#   gpt-oss-20b-mxfp4.gguf
#   Qwen3-Coder-30B-A3B-Instruct-Q4_K_M.gguf
#   Qwen3-Coder-30B-A3B-Instruct-Q6_K.gguf
BENCH_MODEL_FILE=gpt-oss-20b-mxfp4.gguf

# Cache dir (model weights are cached here between runs, speeds up re-runs).
BENCH_CACHE_DIR=/home/dockeruser/.llama_cache

# ── GPU layers ─────────────────────────────────────────────────────────────────
# 99 = offload all layers to VRAM.
BENCH_GPU_LAYERS=99

# ── KV-cache quantization ─────────────────────────────────────────────────────
# Allowed values: f32, f16, bf16, q8_0, q4_0, q4_1, iq4_nl, q5_0, q5_1
BENCH_KV_TYPE_K=q8_0
BENCH_KV_TYPE_V=q8_0

# ── CPU threads (for non-GPU layers, e.g. embedding) ──────────────────────────
BENCH_CPU_THREADS=8

# ── Multi-GPU split ───────────────────────────────────────────────────────────
# Split mode: none (single GPU), layer (default, splits layers+KV), row
BENCH_SPLIT_MODE=none
#BENCH_SPLIT_MODE=layer

# Fraction of model per GPU — '/'-separated proportions (e.g. 1/1 = equal split).
# IMPORTANT: llama-bench uses ',' as a sweep separator (= run once per value).
#            Always use '/' to combine GPUs into ONE run: 1/1, 3/1, etc.
# Ignored when BENCH_SPLIT_MODE=none.
BENCH_TENSOR_SPLIT=1/1

# Primary GPU index (used for intermediate results / KV with split-mode=row).
BENCH_MAIN_GPU=0

# ── Batch sizes ────────────────────────────────────────────────────────────────
BENCH_BATCH_SIZE=2048
BENCH_UBATCH_SIZE=512

# ── Benchmark scenarios ────────────────────────────────────────────────────────
# Comma-separated list of prompt-token counts tested (PP = prompt-processing).
# These values are passed to llama-bench as -p.
BENCH_PP_TOKENS=128,512,2048,4096,8192,16384

# Comma-separated list of generation-token counts tested (TG = token-generation).
# These values are passed to llama-bench as -n.
BENCH_TG_TOKENS=128,512

# Number of repetitions per scenario (higher = more stable average, slower run).
BENCH_REPETITIONS=3

# Output format for llama-bench: md (Markdown table), json, csv, sql
BENCH_OUTPUT_FORMAT=md

# ── ROCm / AMD ────────────────────────────────────────────────────────────────
# GFX version override — needed for RDNA4 (RX 9070 XT = GFX 12.0.1).
# Vega10 (MI25 / WX9100) = 9.0.0 | RDNA3 = 11.0.0 | RDNA4 = 12.0.1
ROCM_GFX_VERSION=12.0.1
# GPU indices to expose — single: "0", dual: "0,1"
ROCM_VISIBLE_DEVICES=0
#ROCM_VISIBLE_DEVICES=0,1

# ── Intel / SYCL ──────────────────────────────────────────────────────────────
# Target a specific Level Zero GPU.
SYCL_DEVICE_FILTER=level_zero:gpu:0
# llama-bench device selector.
BENCH_SYCL_DEVICE=SYCL0

# ── Vulkan ────────────────────────────────────────────────────────────────────
# BENCH_VULKAN_DEVICE selects which Vulkan device(s) llama-bench uses.
# IMPORTANT: llama-bench uses two DIFFERENT separators with different meaning:
#   ','  = sweep — run the benchmark separately for EACH value (one row per device)
#   '/'  = combine — run ONE benchmark using ALL listed devices together
#
# Single GPU:        Vulkan0
# Combined multi-GPU: Vulkan1/Vulkan2   (also set BENCH_SPLIT_MODE=layer above,
#                                        and BENCH_TENSOR_SPLIT with '/' too,
#                                        e.g. BENCH_TENSOR_SPLIT="1/1")
# Sweep (separate per-GPU results): Vulkan0,Vulkan1
BENCH_VULKAN_DEVICE=Vulkan0
#BENCH_VULKAN_DEVICE=Vulkan1
#BENCH_VULKAN_DEVICE=Vulkan1/Vulkan2

# GGML_VK_VISIBLE_DEVICES restricts which Vulkan devices are visible to the
# container at all (by index, comma-separated — this is an env var, not a
# llama-bench flag, so the usual comma list applies here).
# Use this to hide an unwanted device (e.g. an iGPU) before BENCH_VULKAN_DEVICE
# selects among what remains.
GGML_VK_VISIBLE_DEVICES=
#GGML_VK_VISIBLE_DEVICES=0
#GGML_VK_VISIBLE_DEVICES=1,2

# Force RADV (Mesa) Vulkan driver — best for RDNA4.
# Set to '' (empty) to let the system choose, or to 'AMDVLK' for the proprietary driver.
AMD_VULKAN_ICD=RADV

# ── Results ────────────────────────────────────────────────────────────────────
# Directory where result files are written (created automatically).
# Relative paths are resolved from the bench/ directory.
BENCH_RESULTS_DIR=./results

